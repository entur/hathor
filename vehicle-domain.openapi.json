{
  "openapi": "3.0.3",
  "info": {
    "title": "Vehicle Domain API",
    "description": "Simplified vehicle domain model (NeTEx-informed, decoupled). Schemas referenced from vehicle-domain.schema.json.",
    "version": "0.0.1"
  },
  "servers": [{ "url": "https://api.vehicles.example.com/v1" }],
  "paths": {
    "/vehicles": {
      "get": {
        "summary": "List vehicles",
        "operationId": "listVehicles",
        "tags": ["Vehicles"],
        "responses": {
          "200": {
            "description": "Array of vehicles.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Vehicle" }
                }
              }
            }
          }
        }
      }
    },
    "/vehicle-models": {
      "get": {
        "summary": "List vehicle models",
        "operationId": "listVehicleModels",
        "tags": ["Vehicles"],
        "responses": {
          "200": {
            "description": "Array of vehicle models.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/VehicleModel" }
                }
              }
            }
          }
        }
      }
    },
    "/types": {
      "get": {
        "summary": "List concrete types",
        "operationId": "listTypes",
        "tags": ["Types"],
        "responses": {
          "200": {
            "description": "Array of concrete vehicle types (inherits AbstractType).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Type" }
                }
              }
            }
          }
        }
      }
    },
    "/planned-types": {
      "get": {
        "summary": "List planned types",
        "operationId": "listPlannedTypes",
        "tags": ["Types"],
        "responses": {
          "200": {
            "description": "Array of planned vehicle types (inherits AbstractType).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PlannedType" }
                }
              }
            }
          }
        }
      }
    },
    "/transport-modes": {
      "get": {
        "summary": "List transport modes",
        "operationId": "listTransportModes",
        "tags": ["Transport"],
        "responses": {
          "200": {
            "description": "Array of transport modes with nested components.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/TransportMode" }
                }
              }
            }
          }
        }
      }
    },
    "/deck-plans": {
      "get": {
        "summary": "List deck plans",
        "operationId": "listDeckPlans",
        "tags": ["Deck"],
        "responses": {
          "200": {
            "description": "Array of deck plans with full nested tree (decks, levels, spaces, spots, entrances, luggage).",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DeckPlan" }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "TypeKindEnumeration": {
        "$ref": "vehicle-domain.schema.json#/definitions/TypeKindEnumeration"
      },
      "ModeKindEnumeration": {
        "$ref": "vehicle-domain.schema.json#/definitions/ModeKindEnumeration"
      },
      "AbstractType": { "$ref": "vehicle-domain.schema.json#/definitions/AbstractType" },
      "Type": { "$ref": "vehicle-domain.schema.json#/definitions/Type" },
      "PlannedType": { "$ref": "vehicle-domain.schema.json#/definitions/PlannedType" },
      "TransportMode": { "$ref": "vehicle-domain.schema.json#/definitions/TransportMode" },
      "Component": { "$ref": "vehicle-domain.schema.json#/definitions/Component" },
      "Vehicle": { "$ref": "vehicle-domain.schema.json#/definitions/Vehicle" },
      "VehicleModel": { "$ref": "vehicle-domain.schema.json#/definitions/VehicleModel" },
      "DeckPlan": { "$ref": "vehicle-domain.schema.json#/definitions/DeckPlan" },
      "DeckLevel": { "$ref": "vehicle-domain.schema.json#/definitions/DeckLevel" },
      "Deck": { "$ref": "vehicle-domain.schema.json#/definitions/Deck" },
      "PassengerSpace": { "$ref": "vehicle-domain.schema.json#/definitions/PassengerSpace" },
      "PassengerSpot": { "$ref": "vehicle-domain.schema.json#/definitions/PassengerSpot" },
      "PassengerEntrance": { "$ref": "vehicle-domain.schema.json#/definitions/PassengerEntrance" },
      "LuggageSpot": { "$ref": "vehicle-domain.schema.json#/definitions/LuggageSpot" }
    }
  }
}
